  "Pt.449.0049": "２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\nＬｖ．[0134,0003]的时候\n相遇了。",
  "Pt.449.0050": "似乎是在２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\nＬｖ．[0134,0003]的时候\n相遇的。",
  "Pt.449.0051": "２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\nＬｖ．[0134,0003]的时候\n被送来了。",
  "Pt.449.0052": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n所得到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]的时候\n孵化出来了。",
  "Pt.449.0053": "２０[0133,0005]年[0133,0006]月[0133,0007]日在\n[FF00,0002][0104,0008][FF00,0000]\n得到的蛋于\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化。",
  "Pt.449.0054": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n那里拿到的蛋于\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化。",
  "Pt.449.0055": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n那里拿到的蛋于\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化出来的。",
  "Pt.449.0056": "２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\n命中注定般地遇见了\n当时Ｌｖ．[0134,0003]的它。",
  "Pt.449.0057": "２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\n命中注定般地遇见了\n当时Ｌｖ．[0134,0003]的它。",
  "Pt.449.0058": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n得到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
  "Pt.449.0059": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n拿到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
  "Pt.449.0060": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n送来的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
  "Pt.449.0061": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n拿到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
  "Pt.449.0062": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n得到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
  "Pt.449.0063": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n拿到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
