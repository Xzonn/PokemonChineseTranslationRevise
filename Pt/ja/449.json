  "Pt.449.0065": "[FF00,0002]からい[FF00,0000]ものが　すき。",
  "Pt.449.0066": "[FF00,0002]しぶい[FF00,0000]ものが　すき。",
  "Pt.449.0067": "[FF00,0002]あまい[FF00,0000]ものが　すき。",
  "Pt.449.0068": "[FF00,0002]にがい[FF00,0000]ものが　すき。",
  "Pt.449.0069": "[FF00,0002]すっぱい[FF00,0000]ものが　すき。",
  "Pt.449.0070": "なんでも　よくたべる。",
  "Pt.449.0071": "たべるのが　だいすき。",
  "Pt.449.0072": "ひるねを　よくする。",
  "Pt.449.0073": "いねむりが　おおい。",
  "Pt.449.0074": "ものを　よく　ちらかす。",
  "Pt.449.0075": "のんびりするのが　すき。",
  "Pt.449.0076": "ちからが　じまん。",
  "Pt.449.0077": "あばれることが　すき。",
  "Pt.449.0078": "ちょっと　おこりっぽい。",
  "Pt.449.0079": "ケンカを　するのが　すき。",
  "Pt.449.0080": "ちのけが　おおい。",
  "Pt.449.0081": "からだが　じょうぶ。",
  "Pt.449.0082": "うたれ　づよい。",
  "Pt.449.0083": "ねばり　づよい。",
  "Pt.449.0084": "しんぼう　づよい。",
  "Pt.449.0085": "がまん　づよい。",
  "Pt.449.0086": "かけっこが　すき。",
  "Pt.449.0087": "ものおとに　びんかん。",
  "Pt.449.0088": "おっちょこちょい。",
  "Pt.449.0089": "すこし　おちょうしもの。",
  "Pt.449.0090": "にげるのが　はやい。",
  "Pt.449.0091": "こうきしんが　つよい。",
  "Pt.449.0092": "イタズラが　すき。",
  "Pt.449.0093": "ぬけめが　ない。",
  "Pt.449.0094": "かんがえごとが　おおい。",
  "Pt.449.0095": "とても　きちょうめん。",
  "Pt.449.0096": "きが　つよい。",
  "Pt.449.0097": "ちょっぴり　みえっぱり。",
  "Pt.449.0098": "まけんきが　つよい。",
  "Pt.449.0099": "まけずぎらい。",
  "Pt.449.0100": "ちょっぴり　ごうじょう。",
