{
  "HGSS.104.0000": "我就是想要帮助\n你这位战斗狂人的\\r\n招式大叔！\\f\n只要分我一点对战点数，\n我就教给你一些\\r\n技巧型招式！[0200,0000]",
  "HGSS.104.0001": "真是不走运！\n没有这只宝可梦能学会的招式！",
  "HGSS.104.0002": "真是不爽！\n对战点数不够！",
  "HGSS.104.0003": "放弃让[0100,0000]\n学习招式是吧！\\r\n你确定吗？[0200,0000]",
  "HGSS.104.0004": "[0100,0000]想要学习\n[0106,0001]……\\f\n但是\n[0101,0000]已经\\r\n有４个招式了！\\f\n为了学习[0106,0001]，\n要忘记其他的招式吗？[0200,0000]",
  "HGSS.104.0005": "忘记\n[0106,0001]吗？可以吧？[0200,0000]",
  "HGSS.104.0006": "就是说，放弃学习\n[0106,0001]，是吧？[0200,0000]",
  "HGSS.104.0007": "[0100,0000]放弃了学习\n[0106,0001]！",
  "HGSS.104.0008": "１　２……　完成！\\f\n[0100,0000]漂亮地忘记了\n[0106,0001]的用法！\\f\n而且……！\\f\n",
  "HGSS.104.0009": "[0100,0000]学会了\n[0106,0001]！",
  "HGSS.104.0010": "那么！\n期待我们的下次相见啦！",
  "HGSS.104.0011": "我是赌上生命\n进行宝可梦对战的你的强力同伴，\\r\n招式大叔！\\f\n只要分给我点对战点数\n我就教给你一些\\r\n力量型招式！[0200,0000]",
  "HGSS.104.0012": "哦哦～！！\n没有这只宝可梦能学会的招式！",
  "HGSS.104.0013": "哦哦～！！\n对战点数不足！",
  "HGSS.104.0014": "放弃让[0100,0000]\n学习招式吗？[0200,0000]",
  "HGSS.104.0015": "[0100,0000]想要学习\n[0106,0001]……\\f\n但是\n[0101,0000]已经\\r\n有４个招式了！\\f\n为了学习[0106,0001]，\n要忘记其他的招式吗？[0200,0000]",
  "HGSS.104.0016": "遗忘[0106,0001]，\n可以吗？[0200,0000]",
  "HGSS.104.0017": "唔…就是说，放弃学习\\r\n[0106,0001]吗！[0200,0000]",
  "HGSS.104.0018": "[0100,0000]放弃了学习\n[0106,0001]！",
  "HGSS.104.0019": "１　２……　完成！\\f\n[0100,0000]漂亮地忘记了\n[0106,0001]的用法！\\f\n而且……！\\f\n",
  "HGSS.104.0020": "[0100,0000]学会了\n[0106,0001]！",
  "HGSS.104.0021": "那么！下次再来玩吧！",
  "HGSS.104.0022": "我是将灵魂注入\n宝可梦对战的你的温柔的同伴，\\r\n招式大叔！\\f\n只要分给我一些对战点数\n我就教给你一些能\\r\n撼动心灵的招式。[0200,0000]",
  "HGSS.104.0023": "唔……\n没有这只宝可梦能学会的招式啊。",
  "HGSS.104.0024": "哎呀呀……\n对战点数好像不够啊。",
  "HGSS.104.0025": "让[0100,0000]放弃\n学招式吗？[0200,0000]",
  "HGSS.104.0026": "[0100,0000]想要学习\n[0106,0001]……\\f\n但是\n[0101,0000]已经\\r\n有４个招式了！\\f\n为了学习[0106,0001]，\n要忘记其他的招式吗？[0200,0000]",
  "HGSS.104.0027": "遗忘[0106,0001]，\n没错吧？[0200,0000]",
  "HGSS.104.0028": "那么……放弃学习\n[0106,0001]吗？[0200,0000]",
  "HGSS.104.0029": "[0100,0000]放弃了学习\n[0106,0001]！",
  "HGSS.104.0030": "１　２……　完成！\\f\n[0100,0000]漂亮地忘记了\n[0106,0001]！\\f\n而且……！\\f\n",
  "HGSS.104.0031": "[0100,0000]学会了\n[0106,0001]！",
  "HGSS.104.0032": "那么再见！\n积攒了对战点数后\\r\n再来吧！"
