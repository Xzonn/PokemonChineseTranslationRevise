    "HGSS.295.0049": "２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\nＬｖ．[0134,0003]的时候\n相遇了。",
    "HGSS.295.0050": "似乎是在２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\nＬｖ．[0134,0003]的时候\n相遇的。",
    "HGSS.295.0051": "２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\nＬｖ．[0134,0003]的时候\n被送来了。",
    "HGSS.295.0052": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n所得到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]的时候\n孵化出来了。",
    "HGSS.295.0053": "２０[0133,0005]年[0133,0006]月[0133,0007]日在\n[FF00,0002][0104,0008][FF00,0000]\n得到的蛋于\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化。",
    "HGSS.295.0054": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n那里拿到的蛋于\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化。",
    "HGSS.295.0055": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n那里拿到的蛋于\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化出来的。",
    "HGSS.295.0056": "２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\n命中注定般地遇见了\n当时Ｌｖ．[0134,0003]的它。",
    "HGSS.295.0057": "２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\n命中注定般地遇见了\n当时Ｌｖ．[0134,0003]的它。",
    "HGSS.295.0058": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n得到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "HGSS.295.0059": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n拿到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "HGSS.295.0060": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n送来的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "HGSS.295.0061": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n拿到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "HGSS.295.0062": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n得到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "HGSS.295.0063": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n拿到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "HGSS.295.0064": "２０[0133,0000]年[0133,0001]月[0133,0002]日\nＬｖ．[0134,0003]的时候\n从[FF00,0002][0104,0004][FF00,0000]\n传送过来。",
    "HGSS.295.0065": "喜欢[FF00,0002]辣味[FF00,0000]。",
    "HGSS.295.0066": "喜欢[FF00,0002]涩味[FF00,0000]。",
    "HGSS.295.0067": "喜欢[FF00,0002]甜味[FF00,0000]。",
    "HGSS.295.0068": "喜欢[FF00,0002]苦味[FF00,0000]。",
    "HGSS.295.0069": "喜欢[FF00,0002]酸味[FF00,0000]。",
    "HGSS.295.0070": "什么都爱吃。",
    "HGSS.295.0071": "非常喜欢吃东西。",
    "HGSS.295.0072": "经常睡午觉。",
    "HGSS.295.0073": "常常打瞌睡。",
    "HGSS.295.0074": "经常乱扔东西。",
    "HGSS.295.0075": "喜欢悠然自在。",
    "HGSS.295.0076": "以力气大为傲。",
    "HGSS.295.0077": "喜欢胡闹。",
    "HGSS.295.0078": "有点容易生气。",
    "HGSS.295.0079": "喜欢打架。",
    "HGSS.295.0080": "血气方刚。",
    "HGSS.295.0081": "身体强壮。",
    "HGSS.295.0082": "抗打能力强。",
    "HGSS.295.0083": "顽强不屈。",
    "HGSS.295.0084": "能吃苦耐劳。",
    "HGSS.295.0085": "善于忍耐。",
    "HGSS.295.0086": "喜欢比谁跑得快。",
    "HGSS.295.0087": "对声音敏感。",
    "HGSS.295.0088": "冒冒失失。",
    "HGSS.295.0089": "有点容易得意忘形。",
    "HGSS.295.0090": "逃得快。",
    "HGSS.295.0091": "好奇心强。",
    "HGSS.295.0092": "喜欢恶作剧。",
    "HGSS.295.0093": "做事万无一失。",
    "HGSS.295.0094": "经常思考。",
    "HGSS.295.0095": "一丝不苟。",
    "HGSS.295.0096": "性格强势。",
    "HGSS.295.0097": "有一点点爱慕虚荣。",
    "HGSS.295.0098": "争强好胜。",
    "HGSS.295.0099": "不服输。",
    "HGSS.295.0100": "有一点点固执。",
    "HGSS.295.0101": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n拿到的不可思议的\n宝可梦的蛋。\n",
    "HGSS.295.0102": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n拿到的不可思议的\n宝可梦的蛋。\n",
    "HGSS.295.0103": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n在[FF00,0001][0104,0008][FF00,0000]\n拿到的不可思议的\n宝可梦的蛋。\n",
    "HGSS.295.0104": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n那里拿到的不可思议的\n宝可梦的蛋。\n",
    "HGSS.295.0105": "＜蛋的状况＞\n能听到从里面传来的声音！\n好像快要孵出来了！\n",
    "HGSS.295.0106": "＜蛋的状况＞\n好像偶尔在动。\n再过一点时间\n才会孵出来吧？",
    "HGSS.295.0107": "＜蛋的状况＞\n会孵出来什么呢？\n好像还要过段时间\n才会孵出来。",
    "HGSS.295.0108": "＜蛋的状况＞\n这颗蛋孵出来好像\n需要很长一段时间。",
