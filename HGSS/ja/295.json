  "HGSS.295.0061": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0002][0104,0008][FF00,0000]で\nてにいれた　タマゴが\n２０[0133,0000]ねん[0133,0001]がつ[0133,0002]にち\n[FF00,0002][0104,0004][FF00,0000]で\nかえって　うんめいてきな\nであいをした　ようだ。",
  "HGSS.295.0062": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0002][0104,0008][FF00,0000]で\nてにいれた　タマゴが\n２０[0133,0000]ねん[0133,0001]がつ[0133,0002]にち\n[FF00,0002][0104,0004][FF00,0000]で\nかえって　うんめいてきな\nであいをした。",
  "HGSS.295.0063": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0002][0104,0008][FF00,0000]で\nてにいれた　タマゴが\n２０[0133,0000]ねん[0133,0001]がつ[0133,0002]にち\n[FF00,0002][0104,0004][FF00,0000]で\nかえって　うんめいてきな\nであいをした　ようだ。",
  "HGSS.295.0064": "２０[0133,0000]ねん[0133,0001]がつ[0133,0002]にち\nＬｖ．[0134,0003]のとき\n[FF00,0002][0104,0004][FF00,0000]から\nやってきた。",
  "HGSS.295.0065": "[FF00,0002]からい[FF00,0000]ものが　すき。",
  "HGSS.295.0066": "[FF00,0002]しぶい[FF00,0000]ものが　すき。",
  "HGSS.295.0067": "[FF00,0002]あまい[FF00,0000]ものが　すき。",
  "HGSS.295.0068": "[FF00,0002]にがい[FF00,0000]ものが　すき。",
  "HGSS.295.0069": "[FF00,0002]すっぱい[FF00,0000]ものが　すき。",
  "HGSS.295.0070": "なんでも　よくたべる。",
  "HGSS.295.0071": "たべるのが　だいすき。",
  "HGSS.295.0072": "ひるねを　よくする。",
  "HGSS.295.0073": "いねむりが　おおい。",
  "HGSS.295.0074": "ものを　よく　ちらかす。",
  "HGSS.295.0075": "のんびりするのが　すき。",
  "HGSS.295.0076": "ちからが　じまん。",
  "HGSS.295.0077": "あばれることが　すき。",
  "HGSS.295.0078": "ちょっと　おこりっぽい。",
  "HGSS.295.0079": "ケンカを　するのが　すき。",
  "HGSS.295.0080": "ちのけが　おおい。",
  "HGSS.295.0081": "からだが　じょうぶ。",
  "HGSS.295.0082": "うたれ　づよい。",
  "HGSS.295.0083": "ねばり　づよい。",
  "HGSS.295.0084": "しんぼう　づよい。",
  "HGSS.295.0085": "がまん　づよい。",
  "HGSS.295.0086": "かけっこが　すき。",
  "HGSS.295.0087": "ものおとに　びんかん。",
  "HGSS.295.0088": "おっちょこちょい。",
  "HGSS.295.0089": "すこし　おちょうしもの。",
  "HGSS.295.0090": "にげるのが　はやい。",
  "HGSS.295.0091": "こうきしんが　つよい。",
  "HGSS.295.0092": "イタズラが　すき。",
  "HGSS.295.0093": "ぬけめが　ない。",
  "HGSS.295.0094": "かんがえごとが　おおい。",
  "HGSS.295.0095": "とても　きちょうめん。",
  "HGSS.295.0096": "きが　つよい。",
  "HGSS.295.0097": "ちょっぴり　みえっぱり。",
  "HGSS.295.0098": "まけんきが　つよい。",
  "HGSS.295.0099": "まけずぎらい。",
  "HGSS.295.0100": "ちょっぴり　ごうじょう。",
  "HGSS.295.0101": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0002][0104,0008][FF00,0000]から\nもらった　ふしぎな\nポケモンの　タマゴ。\n",
  "HGSS.295.0102": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0002][0104,0008][FF00,0000]で\nてにいれた　ふしぎな\nポケモンの　タマゴ。\n",
  "HGSS.295.0103": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0001][0104,0008][FF00,0000]で\nてにいれた　とっても\nふしぎな　ふしぎな\nポケモンの　タマゴ。\n",
  "HGSS.295.0104": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0002][0104,0008][FF00,0000]から\nやってきた　とっても\nふしぎな　ふしぎな\nポケモンの　タマゴ。\n",
  "HGSS.295.0105": "「タマゴのようす」\nなかから　おとが\nきこえてくる！\nもうすぐ　うまれそう！\n",
  "HGSS.295.0106": "「タマゴのようす」\nときどき　うごいている\nみたい。　うまれるまで\nもう　ちょっとかな？",
  "HGSS.295.0107": "「タマゴのようす」\nなにが　うまれてくるのかな？\nうまれるまで　まだまだ\nじかんが　かかりそう。",
  "HGSS.295.0108": "「タマゴのようす」\nこの　タマゴは\nうまれるまで　かなり\nじかんが　かかりそう。",
