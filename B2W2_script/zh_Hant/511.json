    "B2W2_script.511.0045": "[0202,0000]",
    "B2W2_script.511.0046": "[0201,0000]/[0201,0001]",
    "B2W2_script.511.0047": "取消",
    "B2W2_script.511.0048": "ーーー",
    "B2W2_script.511.0049": "返回",
