    "B2W2_common.179.0049": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]相遇，\n當時Ｌｖ．[0202,0003]。",
    "B2W2_common.179.0050": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]相遇，\n當時Ｌｖ．[0202,0003]。",
    "B2W2_common.179.0051": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n來自[FF00,0002][0105,0004][FF00,0000]，\n當時Ｌｖ．[0202,0003]。",
    "B2W2_common.179.0052": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n通過[FF00,0002][0105,0008][FF00,0000]\n得到蛋。\n２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]\n破殼而出。",
    "B2W2_common.179.0053": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n通過[FF00,0002][0105,0008][FF00,0000]\n得到蛋。\n２０[0201,0000]年[0201,0001]月[0201,0002]日\n似乎是在[FF00,0002][0105,0004][FF00,0000]\n破殼而出的。",
    "B2W2_common.179.0054": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n從[FF00,0002][0105,0008][FF00,0000]處\n得到蛋。\n２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]\n破殼而出。",
    "B2W2_common.179.0055": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n從[FF00,0002][0105,0008][FF00,0000]處\n得到蛋。\n２０[0201,0000]年[0201,0001]月[0201,0002]日\n似乎是在[FF00,0002][0105,0004][FF00,0000]\n破殼而出。",
    "B2W2_common.179.0056": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n通過[FF00,0002][0105,0004][FF00,0000]\n發生了命運的邂逅，\n當時Ｌｖ．[0202,0003]。",
    "B2W2_common.179.0057": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n通過[FF00,0002][0105,0004][FF00,0000]\n發生了命運的邂逅，\n當時Ｌｖ．[0202,0003]。",
    "B2W2_common.179.0058": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n通過[FF00,0002][0105,0008][FF00,0000]\n得到蛋。\n２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]\n破殼而出，\n產生了命運的邂逅。",
    "B2W2_common.179.0059": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n通過[FF00,0002][0105,0008][FF00,0000]\n得到蛋。\n２０[0201,0000]年[0201,0001]月[0201,0002]日\n似乎是在[FF00,0002][0105,0004][FF00,0000]\n破殼而出，\n產生了命運的邂逅。",
    "B2W2_common.179.0060": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n從[FF00,0002][0105,0008][FF00,0000]\n傳送來蛋\n２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]\n破殼而出，\n產生了命運的邂逅。",
    "B2W2_common.179.0061": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n從[FF00,0002][0105,0008][FF00,0000]\n得到蛋。\n２０[0201,0000]年[0201,0001]月[0201,0002]日\n似乎是在[FF00,0002][0105,0004][FF00,0000]\n破殼而出命中註定\n的相遇。",
    "B2W2_common.179.0062": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n通過[FF00,0002][0105,0008][FF00,0000]\n得到蛋。\n２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]\n破殼而出，\n產生了命運的邂逅。",
    "B2W2_common.179.0063": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n通過[FF00,0002][0105,0008][FF00,0000]\n得到蛋。\n２０[0201,0000]年[0201,0001]月[0201,0002]日\n似乎是在[FF00,0002][0105,0004][FF00,0000]\n破殼而出，\n產生了命運的邂逅。",
