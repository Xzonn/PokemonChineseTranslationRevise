    "B2W2_common.380.0049": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002]特別な　場所[FF00,0000]で\n運命的な\n出会いをした\nまぼろしの　ポケモン。",
    "B2W2_common.380.0050": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002]特別な　場所[FF00,0000]で\n運命的な\n出会いをした\nまぼろしの　ポケモン。",
    "B2W2_common.380.0051": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002]特別な　場所[FF00,0000]で\n運命的な\n出会いをした\n伝説の　ポケモン。",
    "B2W2_common.380.0052": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002]特別な　場所[FF00,0000]で\n運命的な\n出会いをした\n伝説の　ポケモン。",
    "B2W2_common.380.0053": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002][0105,0004][FF00,0000]で\n出会った。\nとあるトレーナーと\nトモダチらしい　ちょっと\n珍しい　ポケモン。",
    "B2W2_common.380.0054": "食べるのが　大好き。",
    "B2W2_common.380.0055": "昼寝を　よくする。",
    "B2W2_common.380.0056": "居眠りが　多い。",
    "B2W2_common.380.0057": "ものを　よく　散らかす。",
    "B2W2_common.380.0058": "のんびりするのが　好き。",
    "B2W2_common.380.0059": "力が　自慢。",
    "B2W2_common.380.0060": "暴れることが　好き。",
    "B2W2_common.380.0061": "ちょっと　怒りっぽい。",
    "B2W2_common.380.0062": "ケンカを　するのが　好き。",
    "B2W2_common.380.0063": "血の気が　多い。",
    "B2W2_common.380.0064": "体が　丈夫。",
    "B2W2_common.380.0065": "打たれ強い。",
    "B2W2_common.380.0066": "粘り強い。",
    "B2W2_common.380.0067": "辛抱強い。",
    "B2W2_common.380.0068": "我慢強い。",
    "B2W2_common.380.0069": "駆けっこが　好き。",
    "B2W2_common.380.0070": "物音に　敏感。",
    "B2W2_common.380.0071": "おっちょこちょい。",
    "B2W2_common.380.0072": "すこし　お調子者。",
    "B2W2_common.380.0073": "逃げるのが　早い。",
    "B2W2_common.380.0074": "好奇心が　強い。",
    "B2W2_common.380.0075": "イタズラが　好き。",
    "B2W2_common.380.0076": "抜け目が　ない。",
    "B2W2_common.380.0077": "考え事が　多い。",
    "B2W2_common.380.0078": "とても　きちょうめん。",
    "B2W2_common.380.0079": "気が　強い。",
    "B2W2_common.380.0080": "ちょっぴり　見栄っ張り。",
    "B2W2_common.380.0081": "負けん気が　強い。",
    "B2W2_common.380.0082": "負けず嫌い。",
    "B2W2_common.380.0083": "ちょっぴり　強情。",
    "B2W2_common.380.0084": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n[FF00,0002][0105,0008][FF00,0000]から\nもらった　不思議な\nポケモンの　タマゴ。",
    "B2W2_common.380.0085": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002][0105,0004][FF00,0000]で\n手に入れた　不思議な\nポケモンの　タマゴ。",
    "B2W2_common.380.0086": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n[FF00,0002][0105,0008][FF00,0000]で\n手に入れた　とっても\n不思議な　不思議な\nポケモンの　タマゴ。",
    "B2W2_common.380.0087": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002][0105,0004][FF00,0000]で\n手に入れた\n不思議な　不思議な\nポケモンの　タマゴ。",
    "B2W2_common.380.0088": "「タマゴの様子」\n中から　音が\n聞こえてくる！\nもうすぐ　うまれそう！",
    "B2W2_common.380.0089": "「タマゴの様子」\nときどき　動いている\nみたい。　うまれるまで\nもう　ちょっとかな？",
    "B2W2_common.380.0090": "「タマゴの様子」\nなにが　うまれてくるのかな？\nうまれるまで　まだまだ\n時間が　かかりそう。",
    "B2W2_common.380.0091": "「タマゴの様子」\nこの　タマゴは\nうまれるまで　かなり\n時間が　かかりそう。",
    "B2W2_common.380.0092": "Ｎ"
}
