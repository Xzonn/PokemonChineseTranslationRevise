    "B2W2_common.380.0047": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\nうんめいてきな\nであいをした\n[FF00,0002][0105,0004][FF00,0000]から\nながい　ときを　こえて\nＬｖ．[0202,0003]のとき\nやってきた。",
    "B2W2_common.380.0048": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\nうんめいてきな\nであいをした\n[FF00,0002][0105,0004][FF00,0000]から\nながい　ときを　こえて\nＬｖ．[0202,0003]のとき\nやってきた　ようだ。",
    "B2W2_common.380.0049": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\n[FF00,0002]とくべつな　ばしょ[FF00,0000]で\nうんめいてきな\nであいをした\nまぼろしの　ポケモン。",
    "B2W2_common.380.0050": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\n[FF00,0002]とくべつな　ばしょ[FF00,0000]で\nうんめいてきな\nであいをした\nまぼろしの　ポケモン。",
    "B2W2_common.380.0051": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\n[FF00,0002]とくべつな　ばしょ[FF00,0000]で\nうんめいてきな\nであいをした\nでんせつの　ポケモン。",
    "B2W2_common.380.0052": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\n[FF00,0002]とくべつな　ばしょ[FF00,0000]で\nうんめいてきな\nであいをした\nでんせつの　ポケモン。",
    "B2W2_common.380.0053": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\n[FF00,0002][0105,0004][FF00,0000]で\nであった。\nとあるトレーナーと\nトモダチらしい　ちょっと\nめずらしい　ポケモン。",
    "B2W2_common.380.0054": "たべるのが　だいすき。",
    "B2W2_common.380.0055": "ひるねを　よくする。",
    "B2W2_common.380.0056": "いねむりが　おおい。",
    "B2W2_common.380.0057": "ものを　よく　ちらかす。",
    "B2W2_common.380.0058": "のんびりするのが　すき。",
    "B2W2_common.380.0059": "ちからが　じまん。",
    "B2W2_common.380.0060": "あばれることが　すき。",
    "B2W2_common.380.0061": "ちょっと　おこりっぽい。",
    "B2W2_common.380.0062": "ケンカを　するのが　すき。",
    "B2W2_common.380.0063": "ちのけが　おおい。",
    "B2W2_common.380.0064": "からだが　じょうぶ。",
    "B2W2_common.380.0065": "うたれ　づよい。",
    "B2W2_common.380.0066": "ねばり　づよい。",
    "B2W2_common.380.0067": "しんぼう　づよい。",
    "B2W2_common.380.0068": "がまん　づよい。",
    "B2W2_common.380.0069": "かけっこが　すき。",
    "B2W2_common.380.0070": "ものおとに　びんかん。",
    "B2W2_common.380.0071": "おっちょこちょい。",
    "B2W2_common.380.0072": "すこし　おちょうしもの。",
    "B2W2_common.380.0073": "にげるのが　はやい。",
    "B2W2_common.380.0074": "こうきしんが　つよい。",
    "B2W2_common.380.0075": "イタズラが　すき。",
    "B2W2_common.380.0076": "ぬけめが　ない。",
    "B2W2_common.380.0077": "かんがえごとが　おおい。",
    "B2W2_common.380.0078": "とても　きちょうめん。",
    "B2W2_common.380.0079": "きが　つよい。",
    "B2W2_common.380.0080": "ちょっぴり　みえっぱり。",
    "B2W2_common.380.0081": "まけんきが　つよい。",
    "B2W2_common.380.0082": "まけずぎらい。",
    "B2W2_common.380.0083": "ちょっぴり　ごうじょう。",
    "B2W2_common.380.0084": "２０[0201,0005]ねん[0201,0006]がつ[0201,0007]にち\n[FF00,0002][0105,0008][FF00,0000]から\nもらった　ふしぎな\nポケモンの　タマゴ。",
    "B2W2_common.380.0085": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\n[FF00,0002][0105,0004][FF00,0000]で\nてにいれた　ふしぎな\nポケモンの　タマゴ。",
    "B2W2_common.380.0086": "２０[0201,0005]ねん[0201,0006]がつ[0201,0007]にち\n[FF00,0002][0105,0008][FF00,0000]で\nてにいれた　とっても\nふしぎな　ふしぎな\nポケモンの　タマゴ。",
    "B2W2_common.380.0087": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\n[FF00,0002][0105,0004][FF00,0000]で\nてにいれた\nふしぎな　ふしぎな\nポケモンの　タマゴ。",
    "B2W2_common.380.0088": "「タマゴのようす」\nなかから　おとが\nきこえてくる！\nもうすぐ　うまれそう！",
    "B2W2_common.380.0089": "「タマゴのようす」\nときどき　うごいている\nみたい。　うまれるまで\nもう　ちょっとかな？",
    "B2W2_common.380.0090": "「タマゴのようす」\nなにが　うまれてくるのかな？\nうまれるまで　まだまだ\nじかんが　かかりそう。",
    "B2W2_common.380.0091": "「タマゴのようす」\nこの　タマゴは\nうまれるまで　かなり\nじかんが　かかりそう。",
    "B2W2_common.380.0092": "Ｎ"
}
