    "DP.396.0049": "２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\nＬｖ．[0134,0003]的时候\n相遇了。",
    "DP.396.0050": "似乎是在２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\nＬｖ．[0134,0003]的时候\n相遇的。",
    "DP.396.0051": "２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\nＬｖ．[0134,0003]的时候\n被送来了。",
    "DP.396.0052": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n所得到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]的时候\n孵化出来了。",
    "DP.396.0053": "２０[0133,0005]年[0133,0006]月[0133,0007]日在\n[FF00,0002][0104,0008][FF00,0000]\n得到的蛋于\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化。",
    "DP.396.0054": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n那里拿到的蛋于\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化。",
    "DP.396.0055": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n那里拿到的蛋于\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化出来的。",
    "DP.396.0056": "２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\n命中注定般地遇见了\n当时Ｌｖ．[0134,0003]的它。",
    "DP.396.0057": "２０[0133,0000]年[0133,0001]月[0133,0002]日\n在[FF00,0002][0104,0004][FF00,0000]\n命中注定般地遇见了\n当时Ｌｖ．[0134,0003]的它。",
    "DP.396.0058": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n得到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "DP.396.0059": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n拿到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "DP.396.0060": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n送来的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "DP.396.0061": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n拿到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "DP.396.0062": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n得到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "DP.396.0063": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n[FF00,0002][0104,0008][FF00,0000]\n拿到的蛋在\n２０[0133,0000]年[0133,0001]月[0133,0002]日\n[FF00,0002][0104,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "DP.396.0064": "２０[0133,0000]年[0133,0001]月[0133,0002]日\nＬｖ．[0134,0003]的时候\n从[FF00,0002][0104,0004][FF00,0000]\n传送过来。",
    "DP.396.0065": "喜欢[FF00,0002]辣味[FF00,0000]。",
    "DP.396.0066": "喜欢[FF00,0002]涩味[FF00,0000]。",
    "DP.396.0067": "喜欢[FF00,0002]甜味[FF00,0000]。",
    "DP.396.0068": "喜欢[FF00,0002]苦味[FF00,0000]。",
    "DP.396.0069": "喜欢[FF00,0002]酸味[FF00,0000]。",
    "DP.396.0070": "什么都爱吃。",
    "DP.396.0071": "非常喜欢吃东西。",
    "DP.396.0072": "经常睡午觉。",
    "DP.396.0073": "常常打瞌睡。",
    "DP.396.0074": "经常乱扔东西。",
    "DP.396.0075": "喜欢悠然自在。",
    "DP.396.0076": "以力气大为傲。",
    "DP.396.0077": "喜欢胡闹。",
    "DP.396.0078": "有点容易生气。",
    "DP.396.0079": "喜欢打架。",
    "DP.396.0080": "血气方刚。",
    "DP.396.0081": "身体强壮。",
    "DP.396.0082": "抗打能力强。",
    "DP.396.0083": "顽强不屈。",
    "DP.396.0084": "能吃苦耐劳。",
    "DP.396.0085": "善于忍耐。",
    "DP.396.0086": "喜欢比谁跑得快。",
    "DP.396.0087": "对声音敏感。",
    "DP.396.0088": "冒冒失失。",
    "DP.396.0089": "有点容易得意忘形。",
    "DP.396.0090": "逃得快。",
    "DP.396.0091": "好奇心强。",
    "DP.396.0092": "喜欢恶作剧。",
    "DP.396.0093": "做事万无一失。",
    "DP.396.0094": "经常思考。",
    "DP.396.0095": "一丝不苟。",
    "DP.396.0096": "性格强势。",
    "DP.396.0097": "有一点点爱慕虚荣。",
    "DP.396.0098": "争强好胜。",
    "DP.396.0099": "不服输。",
    "DP.396.0100": "有一点点固执。",
    "DP.396.0101": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n拿到的不可思议的\n宝可梦的蛋。\n",
    "DP.396.0102": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n拿到的不可思议的\n宝可梦的蛋。\n",
    "DP.396.0103": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n在[FF00,0001][0104,0008][FF00,0000]\n拿到的不可思议的\n宝可梦的蛋。\n",
    "DP.396.0104": "２０[0133,0005]年[0133,0006]月[0133,0007]日\n从[FF00,0002][0104,0008][FF00,0000]\n那里拿到的不可思议的\n宝可梦的蛋。\n",
    "DP.396.0105": "＜蛋的状况＞\n能听到从里面传来的声音！\n好像快要孵出来了！\n",
    "DP.396.0106": "＜蛋的状况＞\n好像偶尔在动。\n再过一点时间\n才会孵出来吧？",
    "DP.396.0107": "＜蛋的状况＞\n会孵出来什么呢？\n好像还要过段时间\n才会孵出来。",
    "DP.396.0108": "＜蛋的状况＞\n这颗蛋孵出来好像\n需要很长一段时间。",
