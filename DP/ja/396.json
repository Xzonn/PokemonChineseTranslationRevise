  "DP.396.0061": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0002][0104,0008][FF00,0000]で\nてにいれた　タマゴが\n２０[0133,0000]ねん[0133,0001]がつ[0133,0002]にち\n[FF00,0002][0104,0004][FF00,0000]で\nかえって　うんめいてきな\nであいをした　ようだ。",
  "DP.396.0062": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0002][0104,0008][FF00,0000]で\nてにいれた　タマゴが\n２０[0133,0000]ねん[0133,0001]がつ[0133,0002]にち\n[FF00,0002][0104,0004][FF00,0000]で\nかえって　うんめいてきな\nであいをした。",
  "DP.396.0063": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0002][0104,0008][FF00,0000]で\nてにいれた　タマゴが\n２０[0133,0000]ねん[0133,0001]がつ[0133,0002]にち\n[FF00,0002][0104,0004][FF00,0000]で\nかえって　うんめいてきな\nであいをした　ようだ。",
  "DP.396.0064": "２０[0133,0000]ねん[0133,0001]がつ[0133,0002]にち\nＬｖ．[0134,0003]のとき\n[FF00,0002][0104,0004][FF00,0000]から\nやってきた。",
  "DP.396.0065": "[FF00,0002]からい[FF00,0000]ものが　すき。",
  "DP.396.0066": "[FF00,0002]しぶい[FF00,0000]ものが　すき。",
  "DP.396.0067": "[FF00,0002]あまい[FF00,0000]ものが　すき。",
  "DP.396.0068": "[FF00,0002]にがい[FF00,0000]ものが　すき。",
  "DP.396.0069": "[FF00,0002]すっぱい[FF00,0000]ものが　すき。",
  "DP.396.0070": "なんでも　よくたべる。",
  "DP.396.0071": "たべるのが　だいすき。",
  "DP.396.0072": "ひるねを　よくする。",
  "DP.396.0073": "いねむりが　おおい。",
  "DP.396.0074": "ものを　よく　ちらかす。",
  "DP.396.0075": "のんびりするのが　すき。",
  "DP.396.0076": "ちからが　じまん。",
  "DP.396.0077": "あばれることが　すき。",
  "DP.396.0078": "ちょっと　おこりっぽい。",
  "DP.396.0079": "ケンカを　するのが　すき。",
  "DP.396.0080": "ちのけが　おおい。",
  "DP.396.0081": "からだが　じょうぶ。",
  "DP.396.0082": "うたれ　づよい。",
  "DP.396.0083": "ねばり　づよい。",
  "DP.396.0084": "しんぼう　づよい。",
  "DP.396.0085": "がまん　づよい。",
  "DP.396.0086": "かけっこが　すき。",
  "DP.396.0087": "ものおとに　びんかん。",
  "DP.396.0088": "おっちょこちょい。",
  "DP.396.0089": "すこし　おちょうしもの。",
  "DP.396.0090": "にげるのが　はやい。",
  "DP.396.0091": "こうきしんが　つよい。",
  "DP.396.0092": "イタズラが　すき。",
  "DP.396.0093": "ぬけめが　ない。",
  "DP.396.0094": "かんがえごとが　おおい。",
  "DP.396.0095": "とても　きちょうめん。",
  "DP.396.0096": "きが　つよい。",
  "DP.396.0097": "ちょっぴり　みえっぱり。",
  "DP.396.0098": "まけんきが　つよい。",
  "DP.396.0099": "まけずぎらい。",
  "DP.396.0100": "ちょっぴり　ごうじょう。",
  "DP.396.0101": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0002][0104,0008][FF00,0000]から\nもらった　ふしぎな\nポケモンの　タマゴ。\n",
  "DP.396.0102": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0002][0104,0008][FF00,0000]で\nてにいれた　ふしぎな\nポケモンの　タマゴ。\n",
  "DP.396.0103": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0001][0104,0008][FF00,0000]で\nてにいれた　とっても\nふしぎな　ふしぎな\nポケモンの　タマゴ。\n",
  "DP.396.0104": "２０[0133,0005]ねん[0133,0006]がつ[0133,0007]にち\n[FF00,0002][0104,0008][FF00,0000]から\nやってきた　とっても\nふしぎな　ふしぎな\nポケモンの　タマゴ。\n",
  "DP.396.0105": "「タマゴのようす」\nなかから　おとが\nきこえてくる！\nもうすぐ　うまれそう！\n",
  "DP.396.0106": "「タマゴのようす」\nときどき　うごいている\nみたい。　うまれるまで\nもう　ちょっとかな？",
  "DP.396.0107": "「タマゴのようす」\nなにが　うまれてくるのかな？\nうまれるまで　まだまだ\nじかんが　かかりそう。",
  "DP.396.0108": "「タマゴのようす」\nこの　タマゴは\nうまれるまで　かなり\nじかんが　かかりそう。",
