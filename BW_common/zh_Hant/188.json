    "BW_common.188.0042": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n当时Lv．[0202,0003]的它\n好像是从[FF00,0002][0105,0004][FF00,0000]\n到来了。",
    "BW_common.188.0043": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n当时Lv．[0202,0003]的它\n穿越了久远的时间，\n从[FF00,0002][0105,0004][FF00,0000]\n到来了。",
    "BW_common.188.0044": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n当时Lv．[0202,0003]的它\n穿越了久远的时间，\n好像是从[FF00,0002][0105,0004][FF00,0000]\n到来了。",
    "BW_common.188.0045": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n当时Lv．[0202,0003]的它\n从曾经\n命中注定般相遇的\n[FF00,0002][0105,0004][FF00,0000]\n到来了。",
    "BW_common.188.0046": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n当时Lv．[0202,0003]的它\n好像是从曾经\n命中注定般相遇的\n[FF00,0002][0105,0004][FF00,0000]\n到来了。",
    "BW_common.188.0047": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n当时Lv．[0202,0003]的它\n从曾经\n命中注定般相遇的\n[FF00,0002][0105,0004][FF00,0000]\n穿越了久远的时间\n到来了。",
    "BW_common.188.0048": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n当时Lv．[0202,0003]的它\n好像是从曾经\n命中注定般相遇的\n[FF00,0002][0105,0004][FF00,0000]\n穿越了久远的时间\n到来了。",
    "BW_common.188.0049": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002]在特别的地方[FF00,0000]\n命中注定般\n相遇的\n幻之宝可梦。\n带它去[FF00,0002]飞云市[FF00,0000]\n看看吧。",
    "BW_common.188.0050": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n命中注定般地\n相遇了。[FF00,0002]\n在飞云市的[FF00,0000]\n和朋友索罗亚\n平安地\n重逢了。",
    "BW_common.188.0051": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002]在特别的地方[FF00,0000]\n命中注定般\n相遇的\n幻之宝可梦。\n带它去[FF00,0002]迷幻森林[FF00,0000]\n看看吧。",
    "BW_common.188.0052": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n命中注定般地\n相遇了。[FF00,0002]\n在迷幻森林的[FF00,0000]\n打破了\n索罗亚克的\n幻影。",
    "BW_common.188.0053": "非常喜欢吃东西。",
    "BW_common.188.0054": "经常睡午觉。",
    "BW_common.188.0055": "常常打瞌睡。",
    "BW_common.188.0056": "经常乱扔东西。",
    "BW_common.188.0057": "喜欢悠然自在。",
    "BW_common.188.0058": "以力气大为傲。",
    "BW_common.188.0059": "喜欢胡闹。",
    "BW_common.188.0060": "有点容易生气。",
    "BW_common.188.0061": "喜欢打架。",
    "BW_common.188.0062": "血气方刚。",
    "BW_common.188.0063": "身体强壮。",
    "BW_common.188.0064": "抗打能力强。",
    "BW_common.188.0065": "顽强不屈。",
    "BW_common.188.0066": "能吃苦耐劳。",
    "BW_common.188.0067": "善于忍耐。",
    "BW_common.188.0068": "喜欢比谁跑得快。",
    "BW_common.188.0069": "对声音敏感。",
    "BW_common.188.0070": "冒冒失失。",
    "BW_common.188.0071": "有点容易得意忘形。",
    "BW_common.188.0072": "逃得快。",
    "BW_common.188.0073": "好奇心强。",
    "BW_common.188.0074": "喜欢恶作剧。",
    "BW_common.188.0075": "做事万无一失。",
    "BW_common.188.0076": "经常思考。",
    "BW_common.188.0077": "一丝不苟。",
    "BW_common.188.0078": "性格强势。",
    "BW_common.188.0079": "有一点点爱慕虚荣。",
    "BW_common.188.0080": "争强好胜。",
    "BW_common.188.0081": "不服输。",
    "BW_common.188.0082": "有一点点固执。",
    "BW_common.188.0083": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n从[FF00,0002][0105,0008][FF00,0000]\n获得的不可思议的\n宝可梦蛋。\n",
    "BW_common.188.0084": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]\n获得的不可思议的\n宝可梦蛋。\n",
    "BW_common.188.0085": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n在[FF00,0002][0105,0008][FF00,0000]\n获得的非常不可思议的\n宝可梦蛋。\n",
    "BW_common.188.0086": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n从[FF00,0002][0105,0004][FF00,0000]\n获得的非常不可思议的\n宝可梦蛋。\n",
    "BW_common.188.0087": "“蛋的状况”\n能听到从里面传来的声音！\n好像快要孵出来了！",
    "BW_common.188.0088": "“蛋的状况”\n好像偶尔在动。\n再过一点时间才会孵出来吧？",
    "BW_common.188.0089": "“蛋的状况”\n会孵出来什么呢？好像还要\n过段时间才会孵出来。",
    "BW_common.188.0090": "“蛋的状况”\n这只蛋孵出来好像\n需要很长一段时间。"
