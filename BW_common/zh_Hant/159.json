    "BW_common.159.0049": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]，\n遇见了当时Ｌｖ．[0202,0003]的它。",
    "BW_common.159.0050": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n好像是在[FF00,0002][0105,0004][FF00,0000]，\n遇见了当时Ｌｖ．[0202,0003]的它。",
    "BW_common.159.0051": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]，\n当时Ｌｖ．[0202,0003]的它到来了。",
    "BW_common.159.0052": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n在[FF00,0002][0105,0008][FF00,0000]\n得到的蛋，于２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]孵化了，\n你和它相遇了。",
    "BW_common.159.0053": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n在[FF00,0002][0105,0008][FF00,0000]\n得到的蛋，好像于２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]孵化了，\n你和它相遇了。",
    "BW_common.159.0054": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n从[FF00,0002][0105,0008][FF00,0000]\n得到的蛋，于２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]孵化了，\n你和它相遇了。",
    "BW_common.159.0055": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n从[FF00,0002][0105,0008][FF00,0000]\n得到的蛋，好像于２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]孵化了，\n你和它相遇了。",
    "BW_common.159.0056": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]，\n命中注定般地遇见了当时Ｌｖ．[0202,0003]的它。",
    "BW_common.159.0057": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n好像是在[FF00,0002][0105,0004][FF00,0000]，\n命中注定般地遇见了当时Ｌｖ．[0202,0003]的它。",
    "BW_common.159.0058": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n在[FF00,0002][0105,0008][FF00,0000]\n得到的蛋，于２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "BW_common.159.0059": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n在[FF00,0002][0105,0008][FF00,0000]\n得到的蛋，好像于２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "BW_common.159.0060": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n从[FF00,0002][0105,0008][FF00,0000]\n得到的蛋，于２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "BW_common.159.0061": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n在[FF00,0002][0105,0008][FF00,0000]\n得到的蛋，好像于２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "BW_common.159.0062": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n在[FF00,0002][0105,0008][FF00,0000]\n得到的蛋，于２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "BW_common.159.0063": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n在[FF00,0002][0105,0008][FF00,0000]\n得到的蛋，好像于２０[0201,0000]年[0201,0001]月[0201,0002]日\n在[FF00,0002][0105,0004][FF00,0000]孵化了，\n你和它命中注定般地相遇了。",
    "BW_common.159.0064": "２０[0201,0000]年[0201,0001]月[0201,0002]日，\n当时Ｌｖ．[0202,0003]的它\n从[FF00,0002][0105,0004][FF00,0000]到来了。",
    "BW_common.159.0065": "喜欢[FF00,0002]辛辣[FF00,0000]的东西。",
    "BW_common.159.0066": "喜欢[FF00,0002]涩涩[FF00,0000]的东西。",
    "BW_common.159.0067": "喜欢[FF00,0002]香甜[FF00,0000]的东西。",
    "BW_common.159.0068": "喜欢[FF00,0002]苦味[FF00,0000]的东西。",
    "BW_common.159.0069": "喜欢[FF00,0002]酸味[FF00,0000]的东西。",
    "BW_common.159.0070": "无论什么都喜欢吃。",
    "BW_common.159.0071": "非常喜欢吃东西。",
    "BW_common.159.0072": "经常睡午觉。",
    "BW_common.159.0073": "常常打瞌睡。",
    "BW_common.159.0074": "经常乱扔东西。",
    "BW_common.159.0075": "喜欢悠然自在。",
    "BW_common.159.0076": "以力气大为傲。",
    "BW_common.159.0077": "喜欢胡闹。",
    "BW_common.159.0078": "有点容易生气。",
    "BW_common.159.0079": "喜欢打架。",
    "BW_common.159.0080": "血气方刚。",
    "BW_common.159.0081": "身体强壮。",
    "BW_common.159.0082": "抗打能力强。",
    "BW_common.159.0083": "顽强不屈。",
    "BW_common.159.0084": "能吃苦耐劳。",
    "BW_common.159.0085": "善于忍耐。",
    "BW_common.159.0086": "喜欢比谁跑得快。",
    "BW_common.159.0087": "对声音敏感。",
    "BW_common.159.0088": "冒冒失失。",
    "BW_common.159.0089": "有点容易得意忘形。",
    "BW_common.159.0090": "逃得快。",
    "BW_common.159.0091": "好奇心强。",
    "BW_common.159.0092": "喜欢恶作剧。",
    "BW_common.159.0093": "做事万无一失。",
    "BW_common.159.0094": "经常思考。",
    "BW_common.159.0095": "一丝不苟。",
    "BW_common.159.0096": "性格强势。",
    "BW_common.159.0097": "有一点点爱慕虚荣。",
    "BW_common.159.0098": "争强好胜。",
    "BW_common.159.0099": "不服输。",
    "BW_common.159.0100": "有一点点固执。",
    "BW_common.159.0101": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n从[FF00,0002][0105,0008][FF00,0000]\n获得的不可思议的\n宝可梦蛋。\n",
    "BW_common.159.0102": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n在[FF00,0002][0105,0008][FF00,0000]\n获得的不可思议的\n宝可梦蛋。\n",
    "BW_common.159.0103": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n在[FF00,0001][0105,0008][FF00,0000]\n获得的非常不可思议的\n宝可梦蛋。\n",
    "BW_common.159.0104": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n从[FF00,0002][0105,0008][FF00,0000]\n获得的非常不可思议的\n宝可梦蛋。\n",
    "BW_common.159.0105": "“蛋的状况”\n能听到从里面传来的声音！\n好像快要孵出来了！",
    "BW_common.159.0106": "“蛋的状况”\n好像偶尔在动。\n再过一点时间才会孵出来吧？",
    "BW_common.159.0107": "“蛋的状况”\n会孵出来什么呢？好像还要\n过段时间才会孵出来。",
    "BW_common.159.0108": "“蛋的状况”\n这只蛋孵出来好像\n需要很长一段时间。",
