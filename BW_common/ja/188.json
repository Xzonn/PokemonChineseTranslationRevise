    "BW_common.188.0044": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\n[FF00,0002][0105,0004][FF00,0000]から\nながい　ときを　こえて\nＬｖ．[0202,0003]のとき\nやってきた　ようだ。",
    "BW_common.188.0045": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\nうんめいてきな\nであいをした\n[FF00,0002][0105,0004][FF00,0000]から\nＬｖ．[0202,0003]のとき\nやってきた。",
    "BW_common.188.0046": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\nうんめいてきな\nであいをした\n[FF00,0002][0105,0004][FF00,0000]から\nＬｖ．[0202,0003]のとき\nやってきた　ようだ。",
    "BW_common.188.0047": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\nうんめいてきな\nであいをした\n[FF00,0002][0105,0004][FF00,0000]から\nながい　ときを　こえて\nＬｖ．[0202,0003]のとき\nやってきた。",
    "BW_common.188.0048": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\nうんめいてきな\nであいをした\n[FF00,0002][0105,0004][FF00,0000]から\nながい　ときを　こえて\nＬｖ．[0202,0003]のとき\nやってきた　ようだ。",
    "BW_common.188.0049": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\n[FF00,0002]とくべつな　ばしょ[FF00,0000]で\nうんめいてきな\nであいをした\nまぼろしの　ポケモン。\n[FF00,0002]ヒウンシティ[FF00,0000]に\nつれていってみよう。",
    "BW_common.188.0050": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\nうんめいてきな\nであいをした。\n[FF00,0002]ヒウンシティ[FF00,0000]で\nともだちの　ゾロアと\nぶじに　さいかいすることが\nできた。",
    "BW_common.188.0051": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\n[FF00,0002]とくべつな　ばしょ[FF00,0000]で\nうんめいてきな\nであいをした\nでんせつの　ポケモン。\n[FF00,0002]まよいのもり[FF00,0000]に\nつれていってみよう。",
    "BW_common.188.0052": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\nうんめいてきな\nであいをした。[FF00,0002]\nまよいのもり[FF00,0000]で\nゾロアークの\nイリュージョンを\nうちやぶった。",
    "BW_common.188.0053": "たべるのが　だいすき。",
    "BW_common.188.0054": "ひるねを　よくする。",
    "BW_common.188.0055": "いねむりが　おおい。",
    "BW_common.188.0056": "ものを　よく　ちらかす。",
    "BW_common.188.0057": "のんびりするのが　すき。",
    "BW_common.188.0058": "ちからが　じまん。",
    "BW_common.188.0059": "あばれることが　すき。",
    "BW_common.188.0060": "ちょっと　おこりっぽい。",
    "BW_common.188.0061": "ケンカを　するのが　すき。",
    "BW_common.188.0062": "ちのけが　おおい。",
    "BW_common.188.0063": "からだが　じょうぶ。",
    "BW_common.188.0064": "うたれ　づよい。",
    "BW_common.188.0065": "ねばり　づよい。",
    "BW_common.188.0066": "しんぼう　づよい。",
    "BW_common.188.0067": "がまん　づよい。",
    "BW_common.188.0068": "かけっこが　すき。",
    "BW_common.188.0069": "ものおとに　びんかん。",
    "BW_common.188.0070": "おっちょこちょい。",
    "BW_common.188.0071": "すこし　おちょうしもの。",
    "BW_common.188.0072": "にげるのが　はやい。",
    "BW_common.188.0073": "こうきしんが　つよい。",
    "BW_common.188.0074": "イタズラが　すき。",
    "BW_common.188.0075": "ぬけめが　ない。",
    "BW_common.188.0076": "かんがえごとが　おおい。",
    "BW_common.188.0077": "とても　きちょうめん。",
    "BW_common.188.0078": "きが　つよい。",
    "BW_common.188.0079": "ちょっぴり　みえっぱり。",
    "BW_common.188.0080": "まけんきが　つよい。",
    "BW_common.188.0081": "まけずぎらい。",
    "BW_common.188.0082": "ちょっぴり　ごうじょう。",
    "BW_common.188.0083": "２０[0201,0005]ねん[0201,0006]がつ[0201,0007]にち\n[FF00,0002][0105,0008][FF00,0000]から\nもらった　ふしぎな\nポケモンの　タマゴ。",
    "BW_common.188.0084": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\n[FF00,0002][0105,0004][FF00,0000]で\nてにいれた　ふしぎな\nポケモンの　タマゴ。",
    "BW_common.188.0085": "２０[0201,0005]ねん[0201,0006]がつ[0201,0007]にち\n[FF00,0001][0105,0008][FF00,0000]で\nてにいれた　とっても\nふしぎな　ふしぎな\nポケモンの　タマゴ。",
    "BW_common.188.0086": "２０[0201,0000]ねん[0201,0001]がつ[0201,0002]にち\n[FF00,0002][0105,0004][FF00,0000]で\nてにいれた\nふしぎな　ふしぎな\nポケモンの　タマゴ。",
    "BW_common.188.0087": "「タマゴのようす」\nなかから　おとが\nきこえてくる！\nもうすぐ　うまれそう！",
    "BW_common.188.0088": "「タマゴのようす」\nときどき　うごいている\nみたい。　うまれるまで\nもう　ちょっとかな？",
    "BW_common.188.0089": "「タマゴのようす」\nなにが　うまれてくるのかな？\nうまれるまで　まだまだ\nじかんが　かかりそう。",
    "BW_common.188.0090": "「タマゴのようす」\nこの　タマゴは\nうまれるまで　かなり\nじかんが　かかりそう。"
}
