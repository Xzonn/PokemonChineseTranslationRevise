    "BW_common.188.0044": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002][0105,0004][FF00,0000]から\nながい　ときを　こえて\nＬｖ．[0202,0003]のとき\nやってきた　ようだ。",
    "BW_common.188.0045": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n運命的な\n出会いをした\n[FF00,0002][0105,0004][FF00,0000]から\nＬｖ．[0202,0003]のとき\nやってきた。",
    "BW_common.188.0046": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n運命的な\n出会いをした\n[FF00,0002][0105,0004][FF00,0000]から\nＬｖ．[0202,0003]のとき\nやってきた　ようだ。",
    "BW_common.188.0047": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n運命的な\n出会いをした\n[FF00,0002][0105,0004][FF00,0000]から\nながい　ときを　こえて\nＬｖ．[0202,0003]のとき\nやってきた。",
    "BW_common.188.0048": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n運命的な\n出会いをした\n[FF00,0002][0105,0004][FF00,0000]から\nながい　ときを　こえて\nＬｖ．[0202,0003]のとき\nやってきた　ようだ。",
    "BW_common.188.0049": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002]特別な　場所[FF00,0000]で\n運命的な\n出会いをした\nまぼろしの　ポケモン。\n[FF00,0002]ヒウンシティ[FF00,0000]に\n連れて行ってみよう。",
    "BW_common.188.0050": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n運命的な\n出会いをした。[FF00,0002]\nヒウンシティ[FF00,0000]で\nともだちの　ゾロアと\n無事に　再会することが\nできた。",
    "BW_common.188.0051": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002]特別な　場所[FF00,0000]で\n運命的な\n出会いをした\n伝説の　ポケモン。\n[FF00,0002]迷いの森[FF00,0000]に\n連れて行ってみよう。",
    "BW_common.188.0052": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n運命的な\n出会いをした。[FF00,0002]\n迷いの森[FF00,0000]で\nゾロアークの\nイリュージョンを\n打ち破った。",
    "BW_common.188.0053": "食べるのが　大好き。",
    "BW_common.188.0054": "昼寝を　よくする。",
    "BW_common.188.0055": "居眠りが　多い。",
    "BW_common.188.0056": "ものを　よく　散らかす。",
    "BW_common.188.0057": "のんびりするのが　好き。",
    "BW_common.188.0058": "力が　自慢。",
    "BW_common.188.0059": "暴れることが　好き。",
    "BW_common.188.0060": "ちょっと　怒りっぽい。",
    "BW_common.188.0061": "ケンカを　するのが　好き。",
    "BW_common.188.0062": "血の気が　多い。",
    "BW_common.188.0063": "体が　丈夫。",
    "BW_common.188.0064": "打たれ強い。",
    "BW_common.188.0065": "粘り強い。",
    "BW_common.188.0066": "辛抱強い。",
    "BW_common.188.0067": "我慢強い。",
    "BW_common.188.0068": "駆けっこが　好き。",
    "BW_common.188.0069": "物音に　敏感。",
    "BW_common.188.0070": "おっちょこちょい。",
    "BW_common.188.0071": "すこし　お調子者。",
    "BW_common.188.0072": "逃げるのが　早い。",
    "BW_common.188.0073": "好奇心が　強い。",
    "BW_common.188.0074": "イタズラが　好き。",
    "BW_common.188.0075": "抜け目が　ない。",
    "BW_common.188.0076": "考え事が　多い。",
    "BW_common.188.0077": "とても　きちょうめん。",
    "BW_common.188.0078": "気が　強い。",
    "BW_common.188.0079": "ちょっぴり　見栄っ張り。",
    "BW_common.188.0080": "負けん気が　強い。",
    "BW_common.188.0081": "負けず嫌い。",
    "BW_common.188.0082": "ちょっぴり　強情。",
    "BW_common.188.0083": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n[FF00,0002][0105,0008][FF00,0000]から\nもらった　不思議な\nポケモンの　タマゴ。",
    "BW_common.188.0084": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002][0105,0004][FF00,0000]で\n手に入れた　不思議な\nポケモンの　タマゴ。",
    "BW_common.188.0085": "２０[0201,0005]年[0201,0006]月[0201,0007]日\n[FF00,0002][0105,0008][FF00,0000]で\n手に入れた　とっても\n不思議な　不思議な\nポケモンの　タマゴ。",
    "BW_common.188.0086": "２０[0201,0000]年[0201,0001]月[0201,0002]日\n[FF00,0002][0105,0004][FF00,0000]で\n手に入れた\n不思議な　不思議な\nポケモンの　タマゴ。",
    "BW_common.188.0087": "「タマゴの様子」\n中から　音が\n聞こえてくる！\nもうすぐ　うまれそう！",
    "BW_common.188.0088": "「タマゴの様子」\nときどき　動いている\nみたい。　うまれるまで\nもう　ちょっとかな？",
    "BW_common.188.0089": "「タマゴの様子」\nなにが　うまれてくるのかな？\nうまれるまで　まだまだ\n時間が　かかりそう。",
    "BW_common.188.0090": "「タマゴの様子」\nこの　タマゴは\nうまれるまで　かなり\n時間が　かかりそう。"
}
